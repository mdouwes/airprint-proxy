<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airprint-proxy</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/USERNAME/Repos/airprint-proxy/.venv/bin/airprint-proxy</string>
        <string>YOUR.PRINTER.LAN.IP</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/USERNAME/Library/Logs/airprint-proxy.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/USERNAME/Library/Logs/airprint-proxy.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
